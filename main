import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.TextArea;
import javafx.scene.control.TextField;
import javafx.scene.layout.*;
import javafx.scene.paint.Color;
import javafx.scene.text.Font;
import javafx.scene.text.FontWeight;
import javafx.stage.Stage;

public class Main extends Application {

    @Override
    public void start(Stage stage) {

        BorderPane root = new BorderPane();
        root.setStyle("-fx-background-color: black;");

        // Left Menu
        VBox menu = new VBox();
        menu.setPadding(new Insets(20));

        Button menuButton = new Button("☰");
        menuButton.setFont(Font.font("Arial", FontWeight.BOLD, 30));
        menuButton.setStyle(
                "-fx-background-color: transparent;" +
                "-fx-text-fill: white;" +
                "-fx-cursor: hand;"
        );

        menu.getChildren().add(menuButton);

        // Center Layout
        VBox center = new VBox(20);
        center.setPadding(new Insets(10,30,30,20));

        // Chat Area
        TextArea chatArea = new TextArea();
        chatArea.setEditable(false);
        chatArea.setWrapText(true);
        chatArea.setText("AI response to input, put in bubbles\nboth of them");

        chatArea.setStyle(
                "-fx-control-inner-background:#9e9e9e;" +
                "-fx-background-color:#9e9e9e;" +
                "-fx-background-radius:25;" +
                "-fx-border-radius:25;" +
                "-fx-text-fill:black;" +
                "-fx-font-size:20;"
        );

        chatArea.setPrefHeight(420);

        // Input
        TextField input = new TextField();
        input.setPromptText("input");
        input.setFont(Font.font(24));

        input.setStyle(
                "-fx-background-color:#9e9e9e;" +
                "-fx-background-radius:25;" +
                "-fx-padding:15;" +
                "-fx-text-fill:black;"
        );

        input.setPrefHeight(80);

        center.getChildren().addAll(chatArea, input);

        root.setLeft(menu);
        root.setCenter(center);

        Scene scene = new Scene(root, 960, 540, Color.BLACK);

        stage.setTitle("AI Chat");
        stage.setScene(scene);
        stage.show();
    }

    public static void main(String[] args) {
        launch();
    }
}
