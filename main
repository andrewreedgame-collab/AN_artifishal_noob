public class Main {

    public static void main(String[] args) {

        IntentParser ip = new IntentParser();

        CommunicationEngine sinth = new CommunicationEngine();

        ArtificialNoob an = new ArtificialNoob();

        ArtificialCleaner ac = new ArtificialCleaner();

        String input = "Hello";

        ParsedInput parsed = ip.parse(input);

        ParsedInput translated = sinth.processInput(parsed);

        Response response = an.reason(translated);

        Response cleaned = ac.clean(response);

        String output = sinth.processOutput(cleaned);

        System.out.println(output);
    }
}
